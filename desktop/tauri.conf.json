{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "17Lands",
  "version": "0.1.1",
  "identifier": "com.helloform.seventeenlands",
  "build": {
    "frontendDist": "ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "17Lands",
        "width": 800,
        "height": 560,
        "minWidth": 520,
        "minHeight": 380,
        "visible": false,
        "skipTaskbar": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "Utility",
    "shortDescription": "17Lands MTGA log uploader",
    "longDescription": "Menu-bar app that tails MTG Arena's Player.log and uploads draft/game data to 17Lands.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
