{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Recall",
  "version": "0.2.0",
  "identifier": "com.helloform.recall",
  "build": {
    "frontendDist": "ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Recall",
        "width": 800,
        "height": 560,
        "minWidth": 520,
        "minHeight": 380,
        "visible": false,
        "skipTaskbar": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "Utility",
    "shortDescription": "MTGA log uploader for 17Lands",
    "longDescription": "Menu-bar app that tails MTG Arena's Player.log and uploads draft/game data to 17Lands.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
